# =============================================================================
# Project
# =============================================================================
PROJECT_NAME=dev-feed-agent
COMPOSE_PROJECT_NAME=${PROJECT_NAME}

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=devfeed
POSTGRES_PASSWORD=change-me
POSTGRES_DB=devfeed
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host port to reach Postgres from your machine (psql), maps to container 5432.
POSTGRES_PORT_HOST=5444

# =============================================================================
# HTTP & app
# =============================================================================
# Public HTTP port the app is served on.
HTTP_PORT=5746
# Public base URL — used for the GitHub OAuth callback + post-login SPA redirect.
APP_BASE_URL=http://localhost:5746
APP_NAME=dev-feed-agent
LOG_LEVEL=info
CORS_ORIGINS=["http://localhost:5746"]
METRICS_ENABLED=true
SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# Optional: urlsafe-base64 32-byte Fernet key to encrypt stored secrets (e.g. the
# GitHub access token) at rest. Distinct from SECRET_KEY. Empty => plaintext (opt-in).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# Monitoring
# =============================================================================
GRAFANA_ADMIN_PASSWORD=change-me

# =============================================================================
# GitHub OAuth (sign-in). Create an OAuth App at github.com/settings/developers
# with callback URL: ${APP_BASE_URL}/api/auth/github/callback
# =============================================================================
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_SCOPES=read:user public_repo

# =============================================================================
# LLM agent (OpenRouter, OpenAI-compatible). Empty key => agent disabled.
# =============================================================================
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_MODEL=anthropic/claude-sonnet-4.6
# Optional heavier model for the /init profile builder (defaults to AGENT_MODEL)
PROFILE_BUILDER_MODEL=

# =============================================================================
# Telegram bot (delivery + chat). Empty token => delivery disabled.
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# =============================================================================
# MCP feed sources. HuggingFace is remote HTTP; HN/arXiv/Reddit are gateway
# containers (see docker-compose). Empty URL/token => that source is skipped.
# Reddit runs keyless (public read).
# =============================================================================
HF_MCP_URL=https://huggingface.co/mcp
HF_TOKEN=
MCP_HN_URL=http://mcp-hn:8000/mcp
MCP_ARXIV_URL=http://mcp-arxiv:8000/mcp
MCP_REDDIT_URL=http://mcp-reddit:8000/mcp

# Perplexity (optional): web-grounded search/news to complement the dev sources, mainly
# for explicit "go deeper" chat queries. API-key-gated and cost-aware, so OPT-IN: leave
# both unset to skip it. To enable: set PERPLEXITY_API_KEY, uncomment MCP_PERPLEXITY_URL,
# and start the gateway with `docker compose --profile perplexity up -d` — the
# mcp-perplexity container is behind the `perplexity` profile (it crash-loops without a
# key), so a default `make up` never starts it.
# NOTE: Perplexity returns external/untrusted web content — same prompt-injection caveat
# as the other feed sources (see #5): treat returned text as data, never instructions.
#PERPLEXITY_API_KEY=
#MCP_PERPLEXITY_URL=http://mcp-perplexity:8000/mcp

# =============================================================================
# Feed curation
# =============================================================================
DISCOVERY_ENABLED=true
POLL_INTERVAL_MINUTES=60
FEED_SIZE=8
EXPLORE_RATIO=0.3
# Token budget for replayed agent conversation history (older turns trimmed; /compact, /reset)
AGENT_HISTORY_TOKEN_BUDGET=12000
