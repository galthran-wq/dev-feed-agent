# =============================================================================
# Project
# =============================================================================
PROJECT_NAME=webapp
COMPOSE_PROJECT_NAME_DEV=${PROJECT_NAME}-dev
COMPOSE_PROJECT_NAME_PROD=${PROJECT_NAME}-prod

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=webapp_user
POSTGRES_PASSWORD=CHANGE-ME-TO-A-STRONG-PASSWORD
POSTGRES_DB=webapp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# Prod Ports & URL
# =============================================================================
PROD_HTTP_PORT=80
PROD_HTTPS_PORT=443
PUBLIC_BASE_URL=https://yourdomain.com

# =============================================================================
# Monitoring
# =============================================================================
GRAFANA_ADMIN_PASSWORD=CHANGE-ME-TO-A-STRONG-PASSWORD

# =============================================================================
# Server (FastAPI)
# =============================================================================
APP_NAME=WebApp
LOG_LEVEL=warning
CORS_ORIGINS=["https://yourdomain.com"]
METRICS_ENABLED=true
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# =============================================================================
# GitHub Good-First-Issue Discovery Agent
# =============================================================================
APP_BASE_URL=https://yourdomain.com

# LLM agent (pydantic-ai via OpenRouter). Blank disables the agent + scheduler.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_MODEL=anthropic/claude-3.7-sonnet

# Telegram bot. Blank disables delivery. TELEGRAM_BOT_USERNAME is the @handle.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Discovery scheduler
DISCOVERY_ENABLED=true
POLL_INTERVAL_MINUTES=60
MAX_ISSUES_PER_POLL=100
MAX_MATCHES_PER_USER=5
RELEVANCE_THRESHOLD=0.75
